{
  "name": "template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "auth:gen": "bunx @better-auth/cli generate --output ./server/database/schemas/auth.ts --config ./lib/auth/server.ts",
    "db:gen": "drizzle-kit generate",
    "db:up": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:up:local": "bun ./scripts/migrate-d1.ts --local",
    "db:up:remote": "bun ./scripts/migrate-d1.ts --remote",
    "db:clean:local": "bun ./scripts/clean-d1.ts",
    "db:clean:remote": "bun ./scripts/clean-d1.ts --remote",
    "db:studio": "drizzle-kit studio --port 3000 --verbose"
  },
  "dependencies": {
    "@better-auth/stripe": "1.5.3",
    "@hono/zod-validator": "^0.7.6",
    "@nanostores/react": "^1.0.0",
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "better-auth": "^1.5.4",
    "better-auth-cloudflare": "^0.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.5",
    "lucide-react": "^0.577.0",
    "nanostores": "^1.1.1",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "papaparse": "^5.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-number-format": "^5.4.4",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/node": "^20.19.37",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "baseline-browser-mapping": "^2.10.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.0.0-beta.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
